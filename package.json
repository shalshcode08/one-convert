{
  "name": "one-convert",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "tooling/*",
    "app-web",
    "app-desktop",
    "app-mobile"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@one-convert/app-web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "bunx prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore",
    "format:check": "bunx prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@one-convert/eslint-config": "workspace:*",
    "@one-convert/prettier-config": "workspace:*",
    "@one-convert/tsconfig": "workspace:*",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "bunx eslint --fix",
      "bunx prettier --write"
    ],
    "*.{js,jsx,json,css,md}": [
      "bunx prettier --write"
    ]
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gif.js": "^0.2.0",
    "imagetracerjs": "^1.2.6",
    "immer": "^11.1.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  }
}
